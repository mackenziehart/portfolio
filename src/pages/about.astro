---
import BaseLayout from '../layouts/BaseLayout.astro';
const b = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const experience = [
  {
    org: 'Box',
    orgPeriod: 'Sep 2019 – present',
    roles: [
      {
        title: 'Design Ops Intern',
        period: 'Jan 2025 – Jul 2025 / May 2026 – present',
        bullets: [
          'Owned dependency tracking and led weekly design reviews between Sign\'s Design and Product teams, managing agendas and distributing action items to keep cross-functional commitments on track.',
          'Audited icons across Box\'s design system (Blueprint), surfacing gaps between legacy and updated assets that helped the core team reprioritize.',
          'Designed a Google Sheets tracker to manage a quarter-long content migration for the Blueprint documentation portal, tracking progress across <100 legacy assets and streamlining the migration workflow.',
        ],
      },
      {
        title: 'Copywriter Intern',
        period: 'Jan 2024 – Jul 2024',
        bullets: [
          'Crafted concise and impactful copy for 38 marketing projects, including email campaigns, landing pages, newsletters, and advertisements.',
          'Collaborated with the Brand team, product marketing managers, and designers, ensuring timely and effective copy creation and edits.',
          'Applied SEO best practices to enhance content visibility and reach, driving increased viewership and engagement.',
        ],
      },
      {
        title: 'Sr. Recruiting Coordinator',
        period: 'Sep 2019 – present',
        bullets: [
          'Coordinate an average of 100 interviews/month within SLAs.',
          'Manage Employment Brand internal email program (52 emails annually to entire Recruiting organization), independently developed and optimized three career pages, provided copy review for 22 pages, and created Brand one-pager for Recruiting training.',
        ],
      },
    ],
  },
  {
    org: 'LinkedIn',
    orgPeriod: 'Sep 2018 – Sep 2019',
    roles: [
      {
        title: 'HR Operations Analyst',
        period: 'Sep 2018 – Sep 2019',
        bullets: [
          'Supported HR operations for LinkedIn\'s North American workforce — managed onboarding for up to 20 new hires/week, generated 20+ offers weekly, and drove process improvements across recruiting and HR systems.',
        ],
      },
    ],
  },
];

const education = [
  {
    school: 'California College of the Arts',
    degree: 'MDes, Interaction Design',
    period: 'Sep 2025 – expected Aug 2026',
  },
  {
    school: 'West Valley College',
    degree: 'AS, Interior Design',
    period: 'Sep 2021 – Jun 2024',
  },
  {
    school: 'University of California, Santa Barbara',
    degree: 'BA, English · BA, Psychology',
    period: 'Sep 2014 – Jun 2018',
  },
];

---

<BaseLayout title="About" description="About Mackenzie Hart, Product Designer">
  <div class="about container">

    <header class="about__header">
      <h1>About</h1>
    </header>

    <div class="about__grid">

      <!-- Photo -->
      <aside class="about__photo-col">
        <div class="photo-frame">
          <img src={`${b}polaroid.png`} alt="Mackenzie Hart" class="photo-img" />
        </div>
      </aside>

      <!-- Bio + resume -->
      <div class="about__content">

        <section class="bio" aria-labelledby="bio-heading">
          <h2 id="bio-heading" class="section-label">Bio</h2>
          <div class="bio__body">
            <p>
              I'm Mackenzie Hart. I'm a Silicon Valley baby. I grew up in Sunnyvale, CA
              and have been surrounded by tech all of my life.
            </p>
            <p>
              After a period of exploration — from HR to Recruiting to Interior Design —
              I landed upon Product Design and haven't looked back. <strong>Product design
              marries my endless fascination in human psychology and my affinity for art
              and visual design.</strong> I love designing tools that promote connection
              to others or foster self-understanding.
            </p>
            <p>
              <strong>I graduate from California College of the Arts in August 2026 with
              a Master of Design in Interaction Design.</strong> My background is
              nontraditional, but I view this as a strength; I bring a wealth of
              experience in stakeholder management, program and project management, and
              people leadership in addition to my design skills.
            </p>
          </div>
        </section>

        <a href={`${b}resume.pdf`} class="resume__download" download="Mackenzie Hart Resume 2026.pdf">
          Download résumé <span aria-hidden="true">↓</span>
        </a>

      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .about {
    padding-block: var(--space-32) var(--space-32);
  }

  .about__header {
    margin-bottom: var(--space-16);
    padding-bottom: var(--space-8);
    border-bottom: 4px dotted var(--color-rule);
  }

  .about__grid {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: var(--space-16);
    align-items: start;
  }

  /* Photo */
  .photo-frame {
    position: sticky;
    top: calc(var(--space-6) * 2 + 32px + var(--space-8));
  }

  .photo-img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 400ms cubic-bezier(0.34, 1.56, 0.64, 1);
    transform-origin: center center;
  }

  .photo-frame:hover .photo-img {
    transform: rotate(15deg);
  }

  /* Section labels */
  .section-label {
    font-family: var(--font-sans);
    font-size: var(--size-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-6);
  }

  /* Bio */
  .bio {
    margin-bottom: var(--space-16);
  }

  .bio__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .bio__body p {
    font-size: var(--size-md);
    line-height: 1.6;
  }

  .bio__body strong {
    font-weight: 500;
  }

  /* Resume blocks */
  .resume__block {
    margin-bottom: var(--space-12);
  }

  .resume__sub {
    font-family: var(--font-sans);
    font-size: var(--size-sm);
    font-weight: 500;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-6);
  }

  /* Org grouping */
  .resume__org {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-8);
    border-bottom: 4px dotted var(--color-rule);
  }

  .resume__org:last-child {
    border-bottom: none;
  }

  .resume__org-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .resume__org-name {
    font-weight: 500;
    font-size: var(--size-base);
  }

  /* Individual roles */
  .resume__role {
    margin-bottom: var(--space-4);
    padding-left: var(--space-4);
  }

  .resume__role-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    margin-bottom: var(--space-2);
  }

  .resume__role-title {
    font-size: var(--size-sm);
    color: var(--color-ink);
  }

  .resume__bullets {
    list-style: disc;
    padding-left: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .resume__bullets li {
    font-size: var(--size-sm);
    color: var(--color-ink-muted);
    line-height: 1.6;
  }

  /* Education list */
  .resume__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .resume__item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 4px dotted var(--color-rule);
  }

  .resume__item:last-child {
    border-bottom: none;
  }

  .resume__item-main {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .resume__item-main strong {
    font-weight: 500;
    font-size: var(--size-base);
  }

  .resume__item-main span {
    font-size: var(--size-sm);
    color: var(--color-ink-muted);
  }

  .resume__period {
    font-size: var(--size-sm);
    color: var(--color-ink-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Download */
  .resume__download {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--size-sm);
    color: var(--color-ink);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    transition: color var(--transition);
  }

  .resume__download:hover { color: var(--color-warm); }

  @media (max-width: 768px) {
    .about__grid {
      grid-template-columns: 1fr;
    }

    .photo-frame {
      position: static;
      max-width: 240px;
    }

    .resume__org-header,
    .resume__role-header,
    .resume__item {
      flex-direction: column;
      gap: var(--space-1);
    }
  }
</style>
