---
import BaseLayout from '../layouts/BaseLayout.astro';

const b = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const caseStudies = [
  {
    slug: 'rume',
    title: 'Rume',
    description: 'A contemplative memory collection app.',
    image: `${b}rume-thumb.png`,
    video: `${b}rume-flow.mov`,
    hoverBg: '#000',
  },
  {
    slug: 'aether',
    title: 'Aether',
    description: 'An app that assesses social rhythm and provides mindful methods to benefit mental health.',
    image: `${b}aether-bg.png`,
    gif: `${b}aether-flow.gif`,
    hoverBg: '#fff',
  },
  {
    slug: 'greenroom',
    title: 'Greenroom',
    description: 'A concert logging app for live music lovers.',
    image: `${b}greenroom-bg.png`,
  },
];
---

<BaseLayout title="Work" description="Portfolio of Mackenzie Hart, Product Designer">

  <!-- Custom cursor -->
  <div class="custom-cursor" id="card-cursor" aria-hidden="true">
    <img src={`${b}cursor-card.png`} alt="" />
  </div>

  <!-- Cloud video — fixed behind everything -->
  <div class="cloud-bg" aria-hidden="true">
    <video autoplay muted loop playsinline>
      <source src={`${b}clouds.mp4`} type="video/mp4" />
    </video>
  </div>

  <!-- Hero -->
  <section class="hero" aria-label="Introduction">
    <div class="hero__text">
      <p class="hero__line hero__line--default">
        Mackenzie Hart is a <em>product<br />designer</em> in San Francisco.
      </p>
      <p class="hero__line hero__line--hover" aria-hidden="true">
        Storyteller, life&#8209;<em>romanticizer</em>, and<br />
        <em>obsessed</em> with all of the <em>little details</em>
      </p>
    </div>
  </section>

  <!-- Work — white section that scrolls over the video -->
  <section class="work" aria-label="Case studies">
    <ol class="case-grid" role="list">
      {caseStudies.map((cs) => (
        <li class={`case-card case-card--${cs.slug}`}>
          <div class="case-link" data-hover-bg={cs.hoverBg}>
            <div class="case-thumb" aria-hidden="true">
              {cs.image
                ? <img src={cs.image} alt={cs.title} class="case-thumb__img" />
                : <span>{cs.title[0]}</span>
              }
              {cs.video && (
                <video
                  class="case-thumb__video"
                  src={cs.video}
                  muted
                  loop
                  playsinline
                  preload="none"
                />
              )}
              {cs.gif && (
                <img
                  class="case-thumb__gif"
                  src={cs.gif}
                  alt=""
                  aria-hidden="true"
                />
              )}
            </div>
            <div class="case-text">
              <h2 class="case-title">{cs.title}</h2>
              <p class="case-desc">{cs.description}</p>
            </div>
          </div>
        </li>
      ))}
    </ol>

    <footer class="work-footer">
      <p class="work-footer__sign">Thanks for scrolling.<br /><em>Let's stay connected!</em></p>
      <div class="work-footer__links">
        <a href="mailto:mackenziehart.718@gmail.com">Email</a>
        <a href="https://linkedin.com/in/mackenzie-hart" target="_blank" rel="noopener">LinkedIn</a>
      </div>
    </footer>
  </section>

</BaseLayout>

<script>
  const cursor = document.getElementById('card-cursor') as HTMLElement;

  // Track mouse position and move cursor
  document.addEventListener('mousemove', (e) => {
    cursor.style.transform = `translate(calc(${e.clientX}px - 50%), calc(${e.clientY}px - 50%))`;
  });

  document.querySelectorAll('.case-link').forEach(link => {
    const el = link as HTMLElement;
    const video = link.querySelector('.case-thumb__video') as HTMLVideoElement | null;
    const gif   = link.querySelector('.case-thumb__gif') as HTMLImageElement | null;
    const thumb = link.querySelector('.case-thumb') as HTMLElement | null;
    const hoverBg = el.dataset.hoverBg;

    link.addEventListener('mouseenter', () => {
      cursor.classList.add('visible');
      el.style.cursor = 'none';
      if (hoverBg && thumb) thumb.style.backgroundColor = hoverBg;
      if (video) video.play();
      if (gif) { const s = gif.src; gif.src = ''; gif.src = s; }
    });
    link.addEventListener('mouseleave', () => {
      cursor.classList.remove('visible');
      el.style.cursor = '';
      if (video) { video.pause(); video.currentTime = 0; }
      if (thumb) thumb.style.backgroundColor = '';
    });
  });
</script>

<style>
  /* ── Custom cursor ──────────────────────────────────── */
  .custom-cursor {
    position: fixed;
    top: 0;
    left: 0;
    width: 80px;
    height: 80px;
    pointer-events: none;
    z-index: 999;
    opacity: 0;
    transition: opacity 300ms ease;
    transform: translate(-50%, -50%);
    font-size: 14px;
  }

  .custom-cursor img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .custom-cursor.visible {
    opacity: 1;
  }

  /* ── Cloud bg ───────────────────────────────────────── */
  .cloud-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
  }

  .cloud-bg video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Hero ───────────────────────────────────────────── */
  .hero {
    position: relative;
    z-index: 1;
    height: 100svh;
    display: flex;
    align-items: flex-end;
    padding: 0 var(--space-16) var(--space-16);
  }

  .hero__text {
    position: relative;
    cursor: default;
  }

  .hero__line {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-ink-dark);
    max-width: none;
    transition: opacity 300ms ease;
  }

  .hero__line em {
    font-style: italic;
  }

  .hero__line--hover {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    white-space: nowrap;
  }

  .hero__text:hover .hero__line--default {
    opacity: 0;
  }

  .hero__text:hover .hero__line--hover {
    opacity: 1;
  }

  /* ── Work section ───────────────────────────────────── */
  .work {
    position: relative;
    z-index: 2;
    background: var(--color-bg);
    padding: var(--space-24) var(--space-16) var(--space-32);
  }

  /* Scattered grid — three columns, each offset vertically */
  .case-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
    align-items: start;
    max-width: var(--max-wide);
    margin-inline: auto;
  }

  .case-card--rume      { margin-top: 0; }
  .case-card--aether    { margin-top: var(--space-24); }
  .case-card--greenroom { margin-top: var(--space-8); }

  .case-link {
    display: block;
    text-decoration: none;
  }

  .case-thumb {
    aspect-ratio: 3 / 4;
    background-color: var(--color-surface);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-4);
    overflow: hidden;
    transition: opacity var(--transition);
  }

  .case-thumb span {
    font-family: var(--font-serif);
    font-size: 4rem;
    color: var(--color-rule);
    user-select: none;
  }

  .case-thumb__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 400ms ease;
  }

  .case-thumb__video,
  .case-thumb__gif {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0;
    transition: opacity 400ms ease;
  }

  .case-thumb {
    position: relative;
    transition: background-color 400ms ease;
  }

  .case-link:hover .case-thumb__video,
  .case-link:hover .case-thumb__gif {
    opacity: 1;
  }

  .case-link:hover:has(.case-thumb__video, .case-thumb__gif) .case-thumb__img {
    opacity: 0;
  }

  .case-link:hover .case-thumb {
    opacity: 1;
  }

  .case-title {
    font-family: var(--font-serif);
    font-size: var(--size-md);
    font-weight: 400;
    margin-bottom: var(--space-2);
  }

  .case-desc {
    font-size: var(--size-sm);
    color: var(--color-ink-muted);
    max-width: 28ch;
  }

  /* ── Footer ─────────────────────────────────────────── */
  .work-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-top: var(--space-32);
    padding-top: var(--space-12);
    border-top: 4px dotted var(--color-rule);
    max-width: var(--max-wide);
    margin-inline: auto;
  }

  .work-footer__sign {
    font-family: var(--font-serif);
    font-size: var(--size-lg);
    font-style: italic;
    line-height: 1.3;
    color: var(--color-ink);
    max-width: none;
  }

  .work-footer__sign em {
    font-style: italic;
  }

  .work-footer__links {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-2);
  }

  .work-footer__links a {
    font-family: var(--font-mono);
    font-size: var(--size-sm);
    color: var(--color-ink-muted);
    text-decoration: none;
    transition: color var(--transition);
  }

  .work-footer__links a:hover {
    color: var(--color-ink);
  }

  /* ── Mobile ─────────────────────────────────────────── */
  @media (max-width: 768px) {
    .hero {
      padding: 0 var(--space-6) var(--space-12);
    }

    .hero__line--hover {
      white-space: normal;
    }

    .case-grid {
      grid-template-columns: 1fr;
      gap: var(--space-12);
    }

    .case-card--greenroom,
    .case-card--aether,
    .case-card--rume {
      margin-top: 0;
    }

    .work {
      padding: var(--space-16) var(--space-6) var(--space-24);
    }

    .work-footer {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-8);
    }

    .work-footer__links {
      align-items: flex-start;
    }
  }
</style>
